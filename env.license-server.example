# GeoCMS 授权服务器环境变量配置模板
# 部署域名: sq.moli123.com

# ==================== 数据库配置 ====================
DATABASE_URL="mysql://license_user:YOUR_DB_PASSWORD@localhost:3306/geocms_license?connection_limit=10&pool_timeout=20&connect_timeout=10"

# ==================== 服务器配置 ====================
PORT=4000
NODE_ENV=production
LICENSE_SERVER_URL=https://sq.moli123.com

# ==================== 安全密钥 ====================
# 生成方法: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY
ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_KEY

# ==================== 管理员账户 ====================
ADMIN_EMAIL=admin@moli123.com
ADMIN_PASSWORD=ChangeThisPassword123!

# ==================== CORS 配置 ====================
ALLOWED_ORIGINS=https://client1.moli123.com,https://client2.moli123.com

# ==================== 功能配置 ====================
LICENSE_HEARTBEAT_INTERVAL=3600000
LICENSE_HEARTBEAT_TIMEOUT=30000
ENABLE_TIMESTAMP_PROTECTION=true
ENABLE_HARDWARE_FINGERPRINT=true
OFFLINE_GRACE_PERIOD=72

# ==================== 日志配置 ====================
LOG_LEVEL=info
ENABLE_ACCESS_LOG=true

# ==================== 授权配置 ====================
LICENSE_CODE_PREFIX=GEOCMS
MAX_ACTIVATIONS_PER_LICENSE=3
