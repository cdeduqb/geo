# GeoCMS 环境变量配置示例

# ==================== 数据库配置 ====================
DATABASE_URL="mysql://数据库名:密码@数据库地址:3306/数据库名?connection_limit=10&pool_timeout=20&connect_timeout=10"

# ==================== 站点配置 ====================
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ==================== 跨域配置 (CORS) ====================
# 允许访问 API 的域名列表（逗号分隔）
# 生产环境请配置具体域名，不要使用 *
ALLOWED_ORIGINS=*

# ==================== 授权系统配置 ====================
# 远程授权服务器地址
LICENSE_SERVER_URL=https://sq.moli123.com

# 禁用心跳（设为 true 可减少网络请求）
DISABLE_LICENSE_HEARTBEAT=false

# 可选：授权公钥（用于离线签名验证，从授权服务器获取）
# LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjAN...\n-----END PUBLIC KEY-----"

# ==================== AI 配置 ====================
OPENAI_API_KEY=your-api-key
DEEPSEEK_API_KEY=your-api-key

# ==================== 安全配置 ====================
NEXTAUTH_SECRET=your-super-secret-jwt-key
# 会话时效 (秒)，例如 86400 为 24 小时
SESSION_MAX_AGE=86400
